# TinyCanvas Adventures - build-time configuration (dart-defines)
# There are NO runtime secrets. Never commit real console values to VCS.
#
# Usage:
#   flutter build apk --release \
#     --dart-define=TINYCANVAS_PURCHASE_BACKEND=$TINYCANVAS_PURCHASE_BACKEND \
#     --dart-define=TINYCANVAS_IAP_SKU=$TINYCANVAS_IAP_SKU

# Purchase backend: "mock" (development/tests) or "amazon" (Fire OS release)
TINYCANVAS_PURCHASE_BACKEND=mock

# Amazon IAP entitlement SKU. Placeholder below; replace with the final SKU
# created in the Amazon Developer Console before release.
TINYCANVAS_IAP_SKU=tinycanvas_unlock_all
